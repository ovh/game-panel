#!/usr/bin/env python3
import json
import os
import re
import socketserver
import subprocess
import time
from http.server import BaseHTTPRequestHandler

SOCKET_PATH = "/run/gamepanel/host-agent.sock"
SERVER_ROOT = "/opt/gamepanel/servers"
SSHD_MATCH_FILE = "/etc/ssh/sshd_config.d/gamepanel-sftp-users.conf"
USERNAME_RE = re.compile(r"^gp_s[0-9]+$")
UNIX_USER_RE = re.compile(r"^[a-z_][a-z0-9_-]{0,31}$")


def run(cmd, *, check=True, input_text=None):
    result = subprocess.run(
        cmd,
        input=input_text,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        check=False,
    )

    if check and result.returncode != 0:
        stderr = (result.stderr or "").strip()
        stdout = (result.stdout or "").strip()
        details = stderr if stderr else stdout
        raise RuntimeError(f"command failed ({result.returncode}): {' '.join(cmd)}{': ' + details if details else ''}")

    return result


def ensure_username(username):
    if not isinstance(username, str) or not USERNAME_RE.fullmatch(username):
        raise ValueError("Invalid SFTP username")
    return username


def ensure_unix_user(username):
    if not isinstance(username, str) or not UNIX_USER_RE.fullmatch(username):
        raise ValueError("Invalid app user")
    return username


def ensure_server_path(path_value):
    if not isinstance(path_value, str) or not path_value:
        raise ValueError("Invalid path")

    root = os.path.realpath(SERVER_ROOT)
    real = os.path.realpath(path_value)

    if real == root or not real.startswith(root + os.sep):
        raise ValueError(f"Path outside server root: {real}")

    return real


def user_exists(username):
    return run(["/usr/bin/id", username], check=False).returncode == 0


def has_password(username):
    result = run(["/usr/bin/getent", "shadow", username], check=False)
    if result.returncode != 0:
        return False

    parts = (result.stdout or "").strip().split(":")
    hash_value = parts[1] if len(parts) > 1 else ""
    if not hash_value or hash_value in ("!", "*", "!!"):
        return False
    return True


def set_rw_acl(user, path_value):
    run(["/usr/bin/setfacl", "-R", "-m", f"u:{user}:rwx", path_value])
    run(["/usr/bin/setfacl", "-R", "-d", "-m", f"u:{user}:rwx", path_value])


def terminate_user_sessions(username):
    if run(["/usr/bin/test", "-x", "/usr/bin/loginctl"], check=False).returncode == 0:
        if run(["/usr/bin/loginctl", "terminate-user", username], check=False).returncode == 0:
            time.sleep(0.3)
            return

    run(["/usr/bin/pkill", "-TERM", "-u", username], check=False)
    time.sleep(0.4)
    run(["/usr/bin/pkill", "-KILL", "-u", username], check=False)
    time.sleep(0.2)


class Handler(BaseHTTPRequestHandler):
    def log_message(self, fmt, *args):
        return

    def _read_json(self):
        size = int(self.headers.get("Content-Length", "0"))
        if size < 0 or size > 1024 * 1024:
            raise ValueError("Invalid payload size")
        raw = self.rfile.read(size) if size > 0 else b"{}"
        try:
            value = json.loads(raw.decode("utf-8"))
        except Exception:
            raise ValueError("Invalid JSON payload")
        if not isinstance(value, dict):
            raise ValueError("Payload must be an object")
        return value

    def _send(self, status, payload):
        data = json.dumps(payload).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(data)))
        self.end_headers()
        self.wfile.write(data)

    def do_POST(self):
        try:
            payload = self._read_json()
            data = self._handle(self.path, payload)
            self._send(200, {"ok": True, "data": data})
        except ValueError as err:
            self._send(400, {"ok": False, "error": str(err)})
        except RuntimeError as err:
            self._send(500, {"ok": False, "error": str(err)})
        except Exception:
            self._send(500, {"ok": False, "error": "Unexpected host-agent error"})

    def _handle(self, path, payload):
        if path == "/v1/sftp/ensure-user":
            username = ensure_username(payload.get("username"))
            if not user_exists(username):
                run(["/usr/sbin/useradd", "-M", "-s", "/usr/sbin/nologin", username])
                run(["/usr/sbin/usermod", "-L", username])
            return {"username": username}

        if path == "/v1/sftp/ensure-chroot-permissions":
            username = ensure_username(payload.get("username"))
            app_user = ensure_unix_user(payload.get("app_user"))
            chroot_dir = ensure_server_path(payload.get("chroot_dir"))
            data_dir = ensure_server_path(payload.get("data_dir"))
            backup_dir = ensure_server_path(payload.get("backup_dir"))

            os.makedirs(data_dir, exist_ok=True)
            os.makedirs(backup_dir, exist_ok=True)

            run(["/bin/chown", "root:root", chroot_dir])
            run(["/bin/chmod", "755", chroot_dir])

            set_rw_acl(username, data_dir)
            set_rw_acl(app_user, data_dir)
            set_rw_acl(username, backup_dir)
            set_rw_acl(app_user, backup_dir)
            return {"ok": True}

        if path == "/v1/sftp/has-password":
            username = ensure_username(payload.get("username"))
            return {"has_password": has_password(username)}

        if path == "/v1/sftp/set-password":
            username = ensure_username(payload.get("username"))
            password = payload.get("password")
            if not isinstance(password, str) or len(password) < 1:
                raise ValueError("Invalid password")
            run(["/usr/sbin/chpasswd"], input_text=f"{username}:{password}\n")
            return {"ok": True}

        if path == "/v1/sftp/lock-user":
            username = ensure_username(payload.get("username"))
            run(["/usr/sbin/usermod", "-L", username])
            return {"ok": True}

        if path == "/v1/sftp/unlock-user":
            username = ensure_username(payload.get("username"))
            run(["/usr/sbin/usermod", "-U", username])
            return {"ok": True}

        if path == "/v1/sftp/write-sshd-match":
            entries = payload.get("entries")
            if not isinstance(entries, list):
                raise ValueError("entries must be a list")

            rows = []
            for entry in entries:
                if not isinstance(entry, dict):
                    raise ValueError("Invalid entry")
                username = ensure_username(entry.get("username"))
                chroot_dir = ensure_server_path(entry.get("chroot_dir"))
                rows.append((username, chroot_dir))

            rows.sort(key=lambda item: item[0])

            lines = ["# Auto-generated by Gamepanel. DO NOT EDIT.", ""]
            for username, chroot_dir in rows:
                lines.append(f"Match User {username}")
                lines.append(f"  ChrootDirectory {chroot_dir}")
                lines.append("")
            lines.append("Match all")
            lines.append("")

            with open(SSHD_MATCH_FILE, "w", encoding="utf-8") as file:
                file.write("\n".join(lines))

            run(["/bin/systemctl", "reload", "ssh"])
            return {"ok": True}

        if path == "/v1/sftp/delete-user":
            username = ensure_username(payload.get("username"))
            if not user_exists(username):
                return {"ok": True}

            run(["/usr/sbin/usermod", "-L", username], check=False)
            terminate_user_sessions(username)

            first = run(["/usr/sbin/userdel", username], check=False)
            if first.returncode != 0:
                time.sleep(0.5)
                run(["/usr/sbin/userdel", username])

            return {"ok": True}

        raise ValueError(f"Unknown endpoint: {path}")


class ThreadingUnixHTTPServer(socketserver.ThreadingMixIn, socketserver.UnixStreamServer):
    daemon_threads = True


def main():
    os.makedirs(os.path.dirname(SOCKET_PATH), exist_ok=True)
    if os.path.exists(SOCKET_PATH):
        os.remove(SOCKET_PATH)

    server = ThreadingUnixHTTPServer(SOCKET_PATH, Handler)
    os.chmod(SOCKET_PATH, 0o600)
    server.serve_forever()


if __name__ == "__main__":
    main()
